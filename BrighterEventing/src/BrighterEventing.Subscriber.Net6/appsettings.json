{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Paramore.Brighter.CommandProcessor": "Warning",
      "Paramore.Brighter.MessagingGateway.AzureServiceBus": "Error",
      "Paramore.Brighter.ServiceActivator.Dispatcher": "Information"
    }
  },
  "Testing": {
    "SimulateFailureCount": 0
  },
  "BrighterMessaging": {
    "Subscriber": {
      "Transport": "AzureServiceBus",
      "ImplementInbox": false,
      "DatabaseType": "None",
      "AzureServiceBus": {
        "ConnectionString": "",
        "SubscriptionName": "brighter-eventing-sub",
        "RequireSession": true,
        "MaxDeliveryCount": 5,
        "LockDurationSeconds": 60,
        "DeadLetteringOnMessageExpiration": true,
        "DefaultMessageTimeToLiveDays": 3
      },
      "RabbitMQ": {
        "Exchange": "brighter.eventing.exchange",
        "ClientProvidedName": ""
      },
      "Subscriptions": [
        {
          "EventType": "OrderCreatedEvent",
          "RoutingKey": "orders.created",
          "SubscriptionName": "brighter-eventing-sub-order-created",
          "Topic": "orders-events",
          "AzureServiceBusFilterRules": [
            {
              "Name": "cloudEventsSubjectOnly",
              "Conditions": [
                { "Kind": "Custom", "PropertyName": "cloudEvents:subject", "Value": "orders.created" }
              ]
            }
          ]
        },
        {
          "EventType": "OrderUpdatedEvent",
          "RoutingKey": "orders.updated",
          "SubscriptionName": "brighter-eventing-sub-order-updated",
          "Topic": "orders-events",
          "AzureServiceBusFilterRules": [
            {
              "Name": "brokerSubjectAndEventType",
              "Conditions": [
                { "Kind": "System", "PropertyName": "subject", "Value": "orders.updated" },
                { "Kind": "Custom", "PropertyName": "serviceBusEventType", "Value": "order.updated.v1" }
              ]
            }
          ]
        },
        {
          "EventType": "OrderCancelledEvent",
          "RoutingKey": "orders.cancelled",
          "SubscriptionName": "brighter-eventing-sub-order-cancelled",
          "Topic": "orders-events",
          "AzureServiceBusFilterRules": [
            {
              "Name": "eventTypeOrLegacySubject",
              "Conditions": [
                { "Kind": "Custom", "PropertyName": "serviceBusEventType", "Value": "order.cancelled" }
              ]
            },
            {
              "Name": "alternateSubject",
              "Conditions": [
                { "Kind": "Custom", "PropertyName": "cloudEvents:subject", "Value": "orders.cancelled.legacy" }
              ]
            }
          ]
        }
      ],
      "Consumer": {
        "MaxRetryCount": 3,
        "RequeueDelayMs": 500,
        "ReceiveTimeoutMs": 400
      },
      "Retry": {
        "OutboxProducerMaxRetryAttempts": 1
      }
    }
  }
}
