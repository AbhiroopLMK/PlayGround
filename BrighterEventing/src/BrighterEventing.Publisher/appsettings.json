{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Paramore.Brighter.CommandProcessor": "Warning",
      "Paramore.Brighter.MessagingGateway.AzureServiceBus": "Error"
    }
  },
  "ConnectionStrings": {
    "BrighterOutbox": ""
  },
  "Publisher": {
    "SendIntervalSeconds": 5,
    "OrderCreatedPublishRoutingKey": "orders.created",
    "OrderUpdatedPublishRoutingKey": "orders.updated",
    "OrderCancelledPublishRoutingKey": "orders.cancelled"
  },
  "BrighterMessaging": {
    "Publisher": {
      "Transport": "AzureServiceBus",
      "ImplementOutbox": true,
      "DatabaseType": "PostgreSql",
      "DatabaseName": "neondb",
      "OutboxTableName": "Outbox",
      "AzureServiceBus": {
        "ConnectionString": ""
      },
      "RabbitMQ": {
        "AmqpUri": "",
        "HostName": "",
        "Port": "5672",
        "Username": "",
        "Password": "",
        "Exchange": "brighter.eventing.exchange",
        "ClientProvidedName": ""
      },
      "Publications": [
        {
          "EventType": "OrderCreatedEvent",
          "RoutingKey": "orders.created",
          "Topic": "orders-events"
        },
        {
          "EventType": "OrderUpdatedEvent",
          "RoutingKey": "orders.updated",
          "Topic": "orders-events"
        },
        {
          "EventType": "OrderCancelledEvent",
          "RoutingKey": "orders.cancelled",
          "Topic": "orders-events"
        }
      ],
      "Retry": {
        "OutboxProducerMaxRetryAttempts": 1
      }
    }
  }
}
