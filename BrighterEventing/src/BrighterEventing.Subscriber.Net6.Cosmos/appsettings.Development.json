{
  "Testing": {
    "SimulateFailureCount": 0
  },
  "BrighterMessaging": {
    "Subscriber": {
      "Transport": "AzureServiceBus",
      "ImplementInbox": true,
      "DatabaseType": "CosmosDb",
      "CosmosDb": {
        "Endpoint": "",
        "Key": "",
        "DatabaseId": "brighter-eventing",
        "InboxContainerId": "inbox"
      },
      "AzureServiceBus": {
        "ConnectionString": "",
        "SubscriptionName": "brighter-eventing-sub",
        "RequireSession": true,
        "MaxDeliveryCount": 5,
        "LockDurationSeconds": 60,
        "DeadLetteringOnMessageExpiration": true,
        "DefaultMessageTimeToLiveDays": 3
      },
      "RabbitMQ": {
        "Exchange": "brighter.eventing.exchange",
        "ClientProvidedName": "BrighterEventing.Subscriber.Net6.Cosmos"
      },
      "Subscriptions": [
        {
          "EventType": "OrderCreatedEvent",
          "RoutingKey": "orders.created",
          "SubscriptionName": "brighter-eventing-sub-order-created",
          "Topic": "orders-events"
        },
        {
          "EventType": "OrderUpdatedEvent",
          "RoutingKey": "orders.updated",
          "SubscriptionName": "brighter-eventing-sub-order-updated",
          "Topic": "orders-events"
        },
        {
          "EventType": "OrderCancelledEvent",
          "RoutingKey": "orders.cancelled",
          "SubscriptionName": "brighter-eventing-sub-order-cancelled",
          "Topic": "orders-events"
        }
      ],
      "Consumer": {
        "MaxRetryCount": 3,
        "RequeueDelayMs": 500,
        "ReceiveTimeoutMs": 400
      },
      "Retry": {
        "OutboxProducerMaxRetryAttempts": 1
      }
    }
  }
}
