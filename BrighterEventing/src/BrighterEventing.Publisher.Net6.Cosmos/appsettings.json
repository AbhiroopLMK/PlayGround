{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Paramore.Brighter.CommandProcessor": "Warning",
      "Paramore.Brighter.MessagingGateway.AzureServiceBus": "Error"
    }
  },
  "Publisher": {
    "SendIntervalSeconds": 5,
    "OrderCreatedPublishRoutingKey": "",
    "OrderUpdatedPublishRoutingKey": "",
    "OrderCancelledPublishRoutingKey": ""
  },
  "BrighterMessaging": {
    "Publisher": {
      "Transport": "AzureServiceBus",
      "ImplementOutbox": true,
      "DatabaseType": "CosmosDb",
      "CosmosDb": {
        "Endpoint": "",
        "Key": "",
        "DatabaseId": "brighter-eventing",
        "OutboxContainerId": "outbox"
      },
      "AzureServiceBus": {},
      "RabbitMQ": {
        "Exchange": "brighter.eventing.exchange",
        "ClientProvidedName": "BrighterEventing.Publisher.Net6.Cosmos"
      },
      "Publications": [
        {
          "EventType": "OrderCreatedEvent",
          "RoutingKey": "orders.created",
          "Topic": "orders-events"
        },
        {
          "EventType": "OrderUpdatedEvent",
          "RoutingKey": "orders.updated",
          "Topic": "orders-events",
          "ServiceBusEventType": "order.updated.v1"
        },
        {
          "EventType": "OrderCancelledEvent",
          "RoutingKey": "orders.cancelled",
          "Topic": "orders-events",
          "ServiceBusEventType": "order.cancelled"
        }
      ],
      "Retry": {
        "OutboxProducerMaxRetryAttempts": 1
      }
    }
  }
}
